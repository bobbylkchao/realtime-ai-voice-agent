# API
PORT=4000
LOG_LEVEL=info

## OpenAI API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-realtime-1.5

## Twilio phone (PSTN via Twilio Media Streams)
# When true: TwiML /twilio-phone/incoming-call + WebSocket /twilio-phone/media-stream are registered
TWILIO_PHONE_ENABLE=false
TWILIO_WEBHOOK_URL=ws://localhost:4000/twilio-phone/media-stream

## Amazon Connect phone (OpenAI Realtime SIP webhook)
# When true: POST {base}/incoming-call for OpenAI realtime.call.incoming webhook
AMAZON_CONNECT_PHONE_ENABLE=false
# HTTP path prefix for that webhook (not the Connect instance hostname)
AMAZON_CONNECT_PHONE_WEBHOOK_BASE_PATH=/amazon-connect-phone

# Extra ms to wait after `response.done` before hangup on `transfer_to_human_agent` / `disconnect_the_call` (lets TTS finish on the wire)
# SIP_TRANSFER_AUDIO_TAIL_MS=3500
# SIP_DISCONNECT_AUDIO_TAIL_MS=3500

## Amazon Connect SDK (optional — UpdateContactAttributes, etc.)
# When true: load AWS SDK client; used e.g. when disconnect_the_call updates contact attributes
AMAZON_CONNECT_SDK_ENABLE=false
AMAZON_CONNECT_INSTANCE_ID=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
